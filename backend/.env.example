# Database
POSTGRES_DB=teamart
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/teamart?sslmode=disable

# Database Connection Pool Configuration
# Explicit pool settings for infrastructure ownership
DATABASE_MAX_CONNECTIONS=25
DATABASE_MIN_CONNECTIONS=5
DATABASE_CONN_MAX_LIFETIME=15m
DATABASE_CONN_MAX_IDLE_TIME=5m

# Redis
REDIS_URL=redis://localhost:6379

# Server
SERVER_PORT=8000
SERVER_ENV=development
SERVER_HOST=0.0.0.0

# JWT
JWT_SECRET=ced3084e-f596-47c5-9c7d-efe5906df79f
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
PUBLIC_BASE_URL=http://localhost:8000

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=teamart-uploads

# Kafka
KAFKA_BROKERS=localhost:9092

# Observability
LOG_LEVEL=debug
ENABLE_METRICS=true
ENABLE_TRACING=true
